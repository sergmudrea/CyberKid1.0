// package.json (исправленный, с корректной Jest-конфигурацией и моками)
{
  "name": "cyberkid",
  "version": "0.6.0-alpha",
  "description": "Educational puzzle game that teaches programming from ages 3 to 99",
  "author": "CyberKid Technologies LLC",
  "license": "AGPL-3.0 + Commercial",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "lint": "echo 'No lint configured yet' && exit 0",
    "generate:levels": "tsx tools/generator/index.ts",
    "generate:manifest": "node scripts/generate-level-manifest.js",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "capacitor:sync": "npx cap sync",
    "capacitor:open:android": "npx cap open android",
    "capacitor:open:ios": "npx cap open ios",
    "build:android": "npm run generate:manifest && npm run build && npx cap sync android && npx cap copy android",
    "build:ios": "npm run generate:manifest && npm run build && npx cap sync ios && npx cap copy ios"
  },
  "dependencies": {
    "phaser": "^3.80.1",
    "@capacitor/android": "^6.0.0",
    "@capacitor/ios": "^6.0.0",
    "@capacitor/core": "^6.0.0",
    "@capacitor/app": "^6.0.0",
    "@capacitor/haptics": "^6.0.0",
    "@capacitor/keyboard": "^6.0.0",
    "@capacitor/status-bar": "^6.0.0",
    "workbox-window": "^7.0.0",
    "seedrandom": "^3.0.5"
  },
  "devDependencies": {
    "typescript": "^5.3.3",
    "vite": "^5.0.0",
    "@types/node": "^20.10.0",
    "@types/jest": "^29.5.0",
    "@types/seedrandom": "^3.0.8",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.0",
    "tsx": "^4.6.0",
    "@vitejs/plugin-basic-ssl": "^1.1.0",
    "vite-plugin-pwa": "^0.17.0",
    "workbox-build": "^7.0.0"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "jsdom",
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/src/$1",
      "^phaser$": "<rootDir>/src/__mocks__/phaser.ts"
    },
    "transformIgnorePatterns": [
      "node_modules/(?!(phaser|seedrandom)/)"
    ],
    "collectCoverageFrom": [
      "src/**/*.ts",
      "!src/**/*.test.ts",
      "!src/types/**",
      "!src/main.ts",
      "!src/__mocks__/**"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 50,
        "functions": 50,
        "lines": 50,
        "statements": 50
      }
    }
  }
}
