{
  "name": "cyberkid",
  "version": "0.1.0-alpha",
  "description": "Educational puzzle game that teaches programming from ages 3 to 99",
  "author": "CyberKid Technologies LLC",
  "license": "AGPL-3.0 + Commercial",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "generate:levels": "tsx tools/generator/index.ts",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "capacitor:sync": "npx cap sync",
    "capacitor:open:android": "npx cap open android",
    "capacitor:open:ios": "npx cap open ios",
    "build:android": "npm run build && npx cap sync android && npx cap copy android",
    "build:ios": "npm run build && npx cap sync ios && npx cap copy ios"
  },
  "dependencies": {
    "phaser": "^3.80.1",
    "@capacitor/android": "^6.0.0",
    "@capacitor/ios": "^6.0.0",
    "@capacitor/core": "^6.0.0",
    "@capacitor/app": "^6.0.0",
    "@capacitor/haptics": "^6.0.0",
    "@capacitor/keyboard": "^6.0.0",
    "@capacitor/status-bar": "^6.0.0",
    "workbox-window": "^7.0.0"
  },
  "devDependencies": {
    "typescript": "^5.3.3",
    "vite": "^5.0.0",
    "@types/node": "^20.10.0",
    "@types/jest": "^29.5.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.0",
    "tsx": "^4.6.0",
    "@vitejs/plugin-basic-ssl": "^1.1.0",
    "vite-plugin-pwa": "^0.17.0",
    "workbox-build": "^7.0.0"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "jsdom",
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/src/$1"
    },
    "collectCoverageFrom": [
      "src/**/*.ts",
      "!src/**/*.test.ts",
      "!src/types/**",
      "!src/main.ts"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 70,
        "functions": 70,
        "lines": 70,
        "statements": 70
      }
    }
  }
}
