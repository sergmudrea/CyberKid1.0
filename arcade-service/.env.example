# arcade-service/.env.example
# ПРОМЕТЕЙ: Пример конфигурации окружения для Arcade сервера.
# Скопируйте в .env и заполните своими значениями.

# Порт сервера
PORT=3001

# Секретный ключ для JWT (обязательно измените!)
JWT_SECRET=cyberkid-super-secret-key-change-me-in-production

# Режим разработки (true/false)
NODE_ENV=development

# Путь к файлу базы данных (SQLite)
DB_PATH=./arcade.db

# Лимиты rate limiting (запросов в минуту)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# Настройки CORS (разрешённые домены через запятую)
CORS_ORIGINS=http://localhost:3000,https://cyberkid.example.com

# Включить подробное логирование
DEBUG=true
